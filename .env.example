# ─────────────────────────────────────────────────────────────────────────────
# LoopGuard — Environment Variables Reference
#
# Copy the relevant block into each destination:
#   apps/web/.env.local   ← WEB block
#   apps/api/.env         ← API block
#
# Platform-specific variables (Vercel, GitHub, Railway) are documented below
# but must be set in each platform's dashboard — never in this file.
# ─────────────────────────────────────────────────────────────────────────────


# ── WEB (apps/web/.env.local) ─────────────────────────────────────────────────

# Supabase — supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...anon-key...

# Backend API base URL
#   dev:  http://localhost:3001
#   prod: https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Web app canonical URL (used in auth redirects, OG meta)
#   dev:  http://localhost:3000
#   prod: https://loopguard.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase server-side (used by Next.js API routes — NEVER expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...service-role-key...

# Cron protection: random 32-char hex string
# Generate: openssl rand -hex 32
# Vercel sends this as "Authorization: Bearer <CRON_SECRET>" to cron routes.
CRON_SECRET=replace-with-random-hex-string


# ── API (apps/api/.env) ───────────────────────────────────────────────────────

# Supabase service role — server-side only, never in browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...service-role-key...

# Server
PORT=3001
NODE_ENV=development

# Stripe (activate when billing is ready — Pro tier)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# OpenAI (smart suggestions, Pro only — optional)
# OPENAI_API_KEY=sk-...


# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM SECRETS — set in each platform's dashboard, not here
# ─────────────────────────────────────────────────────────────────────────────


# ── VERCEL (vercel.com → project → Settings → Environment Variables) ──────────
#
# Variable                      Environments    Value
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL      Production, Preview, Development
# NEXT_PUBLIC_SUPABASE_ANON_KEY Production, Preview, Development
# NEXT_PUBLIC_API_URL           Production → https://your-api.up.railway.app
#                               Preview    → https://your-api.up.railway.app
#                               Development → http://localhost:3001
# NEXT_PUBLIC_APP_URL           Production → https://loopguard.vercel.app
#                               Preview    → https://<branch>.loopguard.vercel.app
#                               Development → http://localhost:3000
# SUPABASE_URL                  Production, Preview   (server-side, not Development)
# SUPABASE_SERVICE_ROLE_KEY     Production, Preview   (server-side, not Development)
# CRON_SECRET                   Production, Preview
# STRIPE_SECRET_KEY             Production            (when billing is live)
# STRIPE_WEBHOOK_SECRET         Production            (when billing is live)
# OPENAI_API_KEY                Production, Preview   (when smart suggestions ship)


# ── GITHUB ACTIONS (github.com → repo → Settings → Secrets → Actions) ────────
#
# Secret                       Used in workflow            Purpose
# ─────────────────────────────────────────────────────────────────────────────
# VSCE_TOKEN                   release.yml                 VS Code Marketplace PAT
# API_URL                      keepalive.yml               https://your-api.up.railway.app
# WEB_URL                      keepalive.yml               https://loopguard.vercel.app
# SUPABASE_URL                 keepalive.yml               https://your-project.supabase.co
# SUPABASE_ANON_KEY            keepalive.yml               Supabase anon key (public, safe)
# NPM_TOKEN                    release.yml                 npm automation token (Automation type, not Publish)


# ── RAILWAY / RENDER (API server) ─────────────────────────────────────────────
#
# Variable                    Value
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL                https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY   service role JWT (secret)
# PORT                        3001  (or leave unset — Railway injects $PORT)
# NODE_ENV                    production
# STRIPE_SECRET_KEY           sk_live_...  (when billing is live)
# STRIPE_WEBHOOK_SECRET       whsec_...    (when billing is live)
# OPENAI_API_KEY              sk-...       (when smart suggestions ship)
